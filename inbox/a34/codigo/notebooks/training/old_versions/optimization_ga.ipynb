    "## Análisis Multi-Escenario con NSGA-II\n",
    "\n",
    "HAsta ahora hemos optimizado el proceso para unas condiciones externas en concreto (recordemos 4ºC, 300 min desde limpieza y 0,65bar de aumento de presión).\n",
    "\n",
    "Evaluamos la robustez del optimizador bajo diferentes condiciones operativas:\n",
    "- **Variación de `T_in_leche`**: Simula distintas temperaturas de la leche según estación del año (invierno → verano).\n",
    "- **Variación de `t_ciclo`**: Simula el efecto del ensuciamiento progresivo (inicio de ciclo → necesidad de CIP).\n",
    "- **`Delta_P` representativo**: Para cada `t_ciclo` usamos la mediana histórica de `Delta_P` en ese tramo.\n",
    "\n",
    "Para cada combinación ejecutamos NSGA-II, extraemos el Frente de Pareto y seleccionamos la solución óptima. Se reportan:\n",
    "- `E_consumo_opt` (kW): consumo energético óptimo\n",
    "- `F_flow_opt` (L/h): caudal (producción) correspondiente\n",
    "- `T_out_leche` (°C): temperatura de salida (seguridad alimentaria)\n",
    "- `Consumo_Esp` (kW/(L/h)): consumo específico = eficiencia por unidad producida"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9b9e7c2d",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ==========================================\n",
    "# ANALISIS MULTI-ESCENARIO CON NSGA-II\n",
    "# ==========================================\n",
    "\n",
    "# --- Cargar datos historicos para obtener Delta_P representativo ---\n",
    "DATA_PATH = \"../../data/processed/final_data_sim.csv\"\n",
    "df_hist = pd.read_csv(DATA_PATH)\n",
    "if 'Is_Cleaning' in df_hist.columns:\n",
    "    df_hist = df_hist[df_hist['Is_Cleaning'] == 0].copy()\n",
    "\n",
    "# Escenarios a evaluar\n",
    "T_in_values = [1.0, 2.0, 4.0, 6.0, 8.0]\n",
    "t_ciclo_values = [50, 150, 300, 500, 750]\n",
    "\n",
    "def get_delta_p_for_tciclo(t_cyc, df, window=50):\n",
    "    mask = (df['t_ciclo'] >= t_cyc - window) & (df['t_ciclo'] <= t_cyc + window)\n",
    "    sub = df.loc[mask, 'Delta_P']\n",
    "    return sub.median() if len(sub) > 0 else df['Delta_P'].median()\n",
    "\n",
    "results = []\n",
    "total = len(T_in_values) * len(t_ciclo_values)\n",
    "idx = 0\n",
    "\n",
    "for T_in in T_in_values:\n",
    "    for t_cyc in t_ciclo_values:\n",
    "        idx += 1\n",
    "        dp = get_delta_p_for_tciclo(t_cyc, df_hist)\n",
    "\n",
    "        # Re-registrar fitness con nuevas condiciones\n",
    "        toolbox.unregister(\"evaluate\")\n",
    "        toolbox.register(\"evaluate\", fitness_nsga2, T_in_leche=T_in, t_ciclo=t_cyc, Delta_P=dp)\n",
    "\n",
    "        # Reproducibilidad por escenario\n",
    "        random.seed(1)\n",
    "        np.random.seed(1)\n",
    "\n",
    "        pop_s = toolbox.population(n=GA_CONFIG['pop_size'])\n",
    "        hof_s = tools.ParetoFront()\n",
    "\n",
    "        pop_s, _ = algorithms.eaMuPlusLambda(\n",
    "            pop_s, toolbox,\n",
    "            mu=GA_CONFIG['pop_size'],\n",
    "            lambda_=GA_CONFIG['lambda_'],\n",
    "            cxpb=GA_CONFIG['cxpb'],\n",
    "            mutpb=GA_CONFIG['mutpb'],\n",
    "            ngen=GA_CONFIG['n_gen'],\n",
    "            halloffame=hof_s,\n",
    "            verbose=False\n",
    "        )\n",
    "\n",
    "        # Extraer Pareto front y seleccionar mejor factible\n",
    "        pf = tools.sortNondominated(pop_s, len(pop_s), first_front_only=True)[0]\n",
    "        feasible_s = [(ind, ind.fitness.values[0], ind.fitness.values[1])\n",
    "                      for ind in pf if ind.fitness.values[1] >= T_OUT_MIN]\n",
    "        \n",
    "        if feasible_s:\n",
    "            feasible_s.sort(key=lambda x: x[1])\n",
    "            best_s, E_opt, T_out_opt = feasible_s[0]\n",
    "        else:\n",
    "            best_s = sorted(pf, key=lambda x: x.fitness.values[0])[0]\n",
    "            E_opt, T_out_opt = best_s.fitness.values\n",
    "\n",
    "        n_pareto = len(pf)\n",
    "        n_feasible = len(feasible_s)\n",
    "        consumo_esp = float(E_opt) / max(float(best_s[0]), 1.0)\n",
    "\n",
    "        results.append({\n",
    "            'T_in_leche': T_in,\n",
    "            't_ciclo': t_cyc,\n",
    "            'Delta_P': round(dp, 4),\n",
    "            'F_flow_opt': round(best_s[0], 2),\n",
    "            'T_servicio_opt': round(best_s[1], 2),\n",
    "            'E_consumo_opt': round(float(E_opt), 2),\n",
    "            'T_out_leche': round(float(T_out_opt), 2),\n",
    "            'Consumo_Esp': round(consumo_esp, 5),\n",
    "            'N_Pareto': n_pareto,\n",
    "            'N_Factibles': n_feasible,\n",
    "            'Seguro': 'SI' if T_out_opt >= T_OUT_MIN else 'NO'\n",
    "        })\n",
    "        print(f\"  [{idx}/{total}] T_in={T_in}, t_ciclo={t_cyc}, dP={dp:.3f} \"\n",
    "              f\"-> E={E_opt:.2f} kW, F={best_s[0]:.0f} L/h, T_out={T_out_opt:.2f} C, \"\n",
    "              f\"E/F={consumo_esp:.5f}  (Pareto: {n_pareto}, Factibles: {n_feasible})\")\n",
    "\n",
    "df_results = pd.DataFrame(results)\n",
    "print(\"\\n\" + \"=\" * 100)\n",
    "print(\"RESULTADOS MULTI-ESCENARIO (NSGA-II v1)\")\n",
    "print(\"=\" * 100)\n",
    "print(df_results.to_string(index=False))\n",
    "\n",
    "# Guardar en CSV\n",
    "PREDICTIONS_DIR = \"../../data/predictions\"\n",
    "os.makedirs(PREDICTIONS_DIR, exist_ok=True)\n",
    "df_results.to_csv(f\"{PREDICTIONS_DIR}/ga_optimization_results.csv\", index=False)\n",
    "print(f\"\\nResultados guardados en {PREDICTIONS_DIR}/ga_optimization_results.csv\")"
   ]
  },
