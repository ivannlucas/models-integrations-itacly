    "# ==========================================\n",
    "# FRENTE DE PARETO, CONVERGENCIA Y TABLA\n",
    "# ==========================================\n",
    "sns.set_style(\"whitegrid\")\n",
    "IMAGES_DIR = \"../../data/images\"\n",
    "os.makedirs(IMAGES_DIR, exist_ok=True)\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(18, 12))\n",
    "\n",
    "# --- Frente de Pareto en espacio objetivo (E_consumo vs T_out) ---\n",
    "# Poblacion final completa (gris)\n",
    "all_E = [ind.fitness.values[0] for ind in pop_final]\n",
    "all_T = [ind.fitness.values[1] for ind in pop_final]\n",
    "# representación de todos los individuos de la POBLACIÓN FINAL\n",
    "axes[0, 0].scatter(all_E, all_T, c='lightgray', s=15, alpha=0.5, label='Poblacion final')\n",
    "\n",
    "# Frente de Pareto (azul)\n",
    "pf_sorted = sorted(zip(pareto_E, pareto_T), key=lambda x: x[0])\n",
    "pf_e_sorted = [p[0] for p in pf_sorted]\n",
    "pf_t_sorted = [p[1] for p in pf_sorted]\n",
    "axes[0, 0].plot(pf_e_sorted, pf_t_sorted, 'b-o', markersize=5, linewidth=1.5,\n",
    "             alpha=0.8, label='Frente de Pareto')\n",
    "\n",
    "# Zona infactible\n",
    "axes[0, 0].axhline(y=T_OUT_MIN, color='red', linestyle='--', linewidth=1.5, label=f'T_out min = {T_OUT_MIN} C')\n",
    "axes[0, 0].axhspan(axes[0, 0].get_ylim()[0] if len(all_T) > 0 else 70, T_OUT_MIN,\n",
    "                alpha=0.08, color='red')\n",
    "\n",
    "# Solucion seleccionada\n",
    "axes[0, 0].scatter(best_E, best_T_out, c='red', s=250, marker='*', zorder=10, \n",
    "                edgecolors='black', linewidths=0.8, label='Solucion seleccionada')\n",
    "\n",
    "axes[0, 0].set_xlabel(\"E_consumo (kW)\", fontsize=12)\n",
    "axes[0, 0].set_ylabel(\"T_out_leche (C)\", fontsize=12)\n",
    "axes[0, 0].set_title(\"Frente de Pareto (Espacio Objetivo)\", fontsize=13, fontweight='bold')\n",
    "axes[0, 0].legend(fontsize=8, loc='upper right')\n",
    "axes[0, 0].grid(True, alpha=0.3)\n",
    "\n",
    "# --- Pareto coloreado por F_flow (produccion asociada) ---\n",
    "pareto_F_vals = [ind[0] for ind in pareto_front]\n",
    "sc = axes[0, 1].scatter(\n",
    "    pareto_E, pareto_T,\n",
    "    c=pareto_F_vals,\n",
    "    cmap='viridis', s=60, edgecolors='black', linewidths=0.5, zorder=5\n",
    ")\n",
    "axes[0, 1].scatter(best_E, best_T_out, c='red', s=250, marker='*', zorder=10,\n",
    "                edgecolors='black', linewidths=0.8)\n",
    "axes[0, 1].axhline(y=T_OUT_MIN, color='red', linestyle='--', linewidth=1.0, alpha=0.5)\n",
    "cbar = plt.colorbar(sc, ax=axes[0, 1])\n",
    "cbar.set_label('F_flow (L/h)', fontsize=10)\n",
    "axes[0, 1].set_xlabel(\"E_consumo (kW)\", fontsize=12)\n",
    "axes[0, 1].set_ylabel(\"T_out_leche (C)\", fontsize=12)\n",
    "axes[0, 1].set_title(\"Pareto coloreado por F_flow (Produccion)\", fontsize=13, fontweight='bold')\n",
