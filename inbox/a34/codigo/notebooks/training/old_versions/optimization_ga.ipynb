    "                  T_in_leche=SCENARIO['T_in_leche'],\n",
    "                  t_ciclo=SCENARIO['t_ciclo'],\n",
    "                  Delta_P=SCENARIO['Delta_P'])\n",
    "\n",
    "# Reproducibilidad\n",
    "random.seed(1)\n",
    "np.random.seed(1)\n",
    "\n",
    "# Crear poblacion inicial\n",
    "pop = toolbox.population(n=GA_CONFIG['pop_size'])\n",
    "\n",
    "# --- Estadisticas multi-objetivo ---\n",
    "stats_E = tools.Statistics(key=lambda ind: ind.fitness.values[0])\n",
    "stats_E.register(\"min\", np.min)\n",
    "stats_E.register(\"avg\", np.mean)\n",
    "\n",
    "stats_T = tools.Statistics(key=lambda ind: ind.fitness.values[1])\n",
    "stats_T.register(\"max\", np.max)\n",
    "stats_T.register(\"avg\", np.mean)\n",
    "\n",
    "mstats = tools.MultiStatistics(E_consumo=stats_E, T_out=stats_T)\n",
    "\n",
    "# Hall of Fame para NSGA-II (ParetoFront)\n",
    "hof = tools.ParetoFront()\n",
    "\n",
    "print(f\"Iniciando NSGA-II para escenario: T_in={SCENARIO['T_in_leche']}C, \"\n",
    "      f\"t_ciclo={SCENARIO['t_ciclo']} min, Delta_P={SCENARIO['Delta_P']} bar\")\n",
    "print(\"-\" * 70)\n",
    "\n",
    "t_start = _time.time()\n",
    "\n",
    "# --- Ejecutar NSGA-II con eaMuPlusLambda ---\n",
    "pop_final, logbook = algorithms.eaMuPlusLambda(\n",
    "    pop, toolbox,\n",
    "    mu=GA_CONFIG['pop_size'],\n",
    "    lambda_=GA_CONFIG['lambda_'],\n",
    "    cxpb=GA_CONFIG['cxpb'],\n",
    "    mutpb=GA_CONFIG['mutpb'],\n",
    "    ngen=GA_CONFIG['n_gen'],\n",
    "    stats=mstats,\n",
    "    halloffame=hof,\n",
    "    verbose=True\n",
    ")\n",
    "\n",
    "t_elapsed = _time.time() - t_start\n",
    "\n",
    "# --- Extraer Frente de Pareto ---\n",
    "pareto_front = tools.sortNondominated(pop_final, len(pop_final), first_front_only=True)[0]\n",
    "pareto_E = [ind.fitness.values[0] for ind in pareto_front]\n",
    "pareto_T = [ind.fitness.values[1] for ind in pareto_front]\n",
    "\n",
    "# --- Filtrar soluciones factibles (T_out >= 72.3 C) ---\n",
    "feasible = [(ind, ind.fitness.values[0], ind.fitness.values[1])\n",
    "            for ind in pareto_front if ind.fitness.values[1] >= T_OUT_MIN]\n",
    "\n",
    "if feasible:\n",
    "    # Seleccionar la de minimo E_consumo entre las factibles\n",
    "    feasible.sort(key=lambda x: x[1])\n",
    "    best_ind, best_E, best_T_out = feasible[0]\n",
    "    best_F_flow, best_T_servicio = best_ind\n",
    "else:\n",
    "    # Fallback: mejor E_consumo del frente completo\n",
    "    sorted_pareto = sorted(pareto_front, key=lambda ind: ind.fitness.values[0])\n",
    "    best_ind = sorted_pareto[0]\n",
    "    best_F_flow, best_T_servicio = best_ind\n",
    "    best_E, best_T_out = best_ind.fitness.values\n",
    "\n",
    "# --- Calcular consumo especifico (eficiencia por unidad producida) ---\n",
    "best_consumo_esp = float(best_E) / max(float(best_F_flow), 1.0)\n",
    "\n",
    "# Etiquetas para el print (evitar backslash en f-string)\n",
    "t_out_status = \"OK\" if best_T_out >= T_OUT_MIN else \"VIOLA RESTRICCION\"\n",
    "\n",
    "print(\"=\" * 70)\n",
    "print(\"FRENTE DE PARETO (escenario base)\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"   Soluciones en el frente de Pareto:  {len(pareto_front)}\")\n",
    "print(f\"   Soluciones factibles (T_out>=72.3C):  {len(feasible)}\")\n",
    "print(f\"   Rango E_consumo: [{min(pareto_E):.2f}, {max(pareto_E):.2f}] kW\")\n",
    "print(f\"   Rango T_out:     [{min(pareto_T):.2f}, {max(pareto_T):.2f}] C\")\n",
    "print(\"-\" * 70)\n",
    "print(\"SOLUCION SELECCIONADA (min E_consumo con T_out >= 72.3 C)\")\n",
    "print(\"-\" * 70)\n",
    "print(f\"   F_flow*          = {best_F_flow:.2f} L/h\")\n",
    "print(f\"   T_servicio*      = {best_T_servicio:.2f} C\")\n",
    "print(f\"   E_consumo        = {best_E:.2f} kW\")\n",
    "print(f\"   T_out_leche      = {best_T_out:.2f} C  [{t_out_status}]\")\n",
    "print(f\"   Consumo espec.   = {best_consumo_esp:.5f} kW/(L/h)\")\n",
    "print(f\"   Tiempo NSGA-II:  {t_elapsed:.2f} s\")"
   ]
