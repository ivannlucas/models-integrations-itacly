    "print(\"-\" * 85)\n",
    "print(f\"{'F_flow (L/h)':<28} | {hist_F_flow:<15.2f} | {best_F_flow:<15.2f} | {cambio_flow:<+12.2f}\")\n",
    "print(f\"{'T_servicio (C)':<28} | {hist_T_servicio:<15.2f} | {best_T_servicio:<15.2f} | {best_T_servicio - hist_T_servicio:<+12.2f}\")\n",
    "print(f\"{'E_consumo (kW)':<28} | {float(E_hist_pred):<15.2f} | {best_E:<15.2f} | {best_E - float(E_hist_pred):<+12.2f}\")\n",
    "print(f\"{'T_out_leche (C)':<28} | {float(T_hist_pred):<15.2f} | {best_T_out:<15.2f} | {best_T_out - float(T_hist_pred):<+12.2f}\")\n",
    "print(f\"{'Consumo espec. E/F':<28} | {ce_hist:<15.5f} | {best_consumo_esp:<15.5f} | {best_consumo_esp - ce_hist:<+12.5f}\")\n",
