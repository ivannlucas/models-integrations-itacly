# --- Jupyter Notebooks ---
.ipynb_checkpoints
profile_default/
ipython_config.py

# --- Model Artifacts  ---
# Ignoramos los binarios pesados en producción y checkpoints
models/*
models/prod/*.pkl
models/prod/*.h5
models/checkpoints/*

# Extensiones generales para asegurar que no se cuelen modelos pesados
*.h5
*.pth
*.pt
*.onnx
*.tflite
# *.pkl (Comentado porque a veces es útil para configs pequeñas, pero models/prod/*.pkl ya lo cubre)

# --- Data Structure (Estrategia Inteligente) ---
# 1. Ignorar TODO el contenido dentro de data
data/*
# 2. Excepción: No ignorar subcarpetas (para mantener raw/processed)
!data/**/
# 3. Excepción: No ignorar los .gitkeep para que Git suba las carpetas
!data/**/.gitkeep
# 4. Excepción: No ignorar el README explicativo
!data/README.md

# --- Scraper Output & Logs ---
scrapers/*.log
*.log

# --- Output & Reports ---
# Ignorar resultados de ejecuciones (métricas y predicciones)
output/
outputs/
reports/
results/

reports/metrics/*.csv
reports/metrics/*.json
reports/figures/*.pdf
# !reports/figures/*.png  <-- Descomenta si quieres subir gráficas generadas

# --- Testing & Coverage ---
.pytest_cache/
.coverage
htmlcov/
TEST*.xml

# --- Security (Secrets) ---
.env
.env.local
secrets.json

# --- Documentation Images ---
# Asegurar que la imagen del README principal SÍ se suba
!image_f8ccd6.png

# --- Large Media & Misc (Del archivo genérico) ---
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv
